{
  "name": "v7-new-docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build && node ace build:static && npm run build:search:index",
    "build:search:index": "pagefind --site build/public",
    "dev:search:index": "pagefind --site build/public --output-path=public/pagefind",
    "predev": "npm run dev:search:index",
    "dev": "node ace serve --hmr",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#services/*": "./app/services/*.js",
    "#collections/*": "./app/collections/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/eslint-config": "^3.1.0",
    "@adonisjs/prettier-config": "^1.5.0",
    "@adonisjs/tsconfig": "^2.0.0",
    "@alpinejs/collapse": "^3.15.12",
    "@pagefind/component-ui": "^1.5.2",
    "@poppinss/ts-exec": "^1.4.4",
    "@resvg/resvg-js": "^2.6.2",
    "@types/alpinejs": "^3.13.11",
    "@types/node": "^26.1.0",
    "alpinejs": "^3.15.12",
    "eslint": "^10.6.0",
    "hot-hook": "^1.0.0",
    "pagefind": "^1.5.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.4",
    "satori": "^0.26.0",
    "sharp": "^0.35.3",
    "typescript": "~6.0",
    "unpoly": "^3.14.3",
    "vite": "^8.1.3",
    "youch": "^4.1.1"
  },
  "dependencies": {
    "@adonisjs/content": "^1.7.1",
    "@adonisjs/core": "^7.3.4",
    "@adonisjs/static": "^2.0.1",
    "@adonisjs/vite": "^6.0.0-next.1",
    "@github/tab-container-element": "^4.8.2",
    "@iconify-json/mynaui": "^1.2.17",
    "@iconify-json/tabler": "^1.2.35",
    "@iconify-json/uiw": "^1.2.4",
    "@tailwindcss/vite": "^4.3.2",
    "@types/luxon": "^3.7.2",
    "@vinejs/vine": "^4.4.0",
    "edge-iconify": "^2.0.2",
    "edge-markdown": "^1.10.2",
    "edge.js": "^6.5.1",
    "hast-util-to-text": "^4.0.2",
    "luxon": "^3.7.2",
    "posthog-js": "^1.396.6",
    "reflect-metadata": "^0.2.2",
    "remark-mdc": "^3.11.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.2",
    "tippy.js": "^6.3.7"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
